# Copy to ``.env``. All keys are required (no in-code defaults).

APP_NAME=event-platform-notification-service
LOG_LEVEL=INFO

RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=admin

RABBITMQ_EVENTS_EXCHANGE=events.topic
RABBITMQ_EVENTS_EXCHANGE_TYPE=topic

RABBITMQ_NOTIFICATION_QUEUE=notification.email
RABBITMQ_NOTIFICATION_BINDING_KEYS=user.*,order.created,payment.failed,notification.retry.5s,notification.retry.30s,notification.retry.120s

RETRY_QUEUE_1=notification.retry.5s
RETRY_QUEUE_2=notification.retry.30s
RETRY_QUEUE_3=notification.retry.120s
RETRY_TTL_1=5000
RETRY_TTL_2=30000
RETRY_TTL_3=120000

RABBITMQ_DLQ_EXCHANGE=notification.dlq.exchange
RABBITMQ_DLQ_QUEUE=notification.email.dlq
RABBITMQ_DLQ_ROUTING_KEY=notification.email.dlq

RABBITMQ_PREFETCH=10
NOTIFICATION_MAX_RETRIES=3

# Docker Compose only (must match event-platform-infra / gateway)
EVENT_PLATFORM_NETWORK_NAME=event-platform-net
